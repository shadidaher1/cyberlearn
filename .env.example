# ──────────────────────────────────────────────────────────────────────────
#  CyberLearn — environment variables
#  Copy to `.env` and fill in. NEVER commit real secrets (see docs/SECURITY.md).
#  Generate strong secrets with:  openssl rand -base64 48
# ──────────────────────────────────────────────────────────────────────────

# ── App ──
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (Neon, Postgres) ──
# Pooled connection (PgBouncer) — used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/cyberlearn?sslmode=require"
# Direct connection — used by Prisma Migrate only (never pooled).
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/cyberlearn?sslmode=require"

# ── Auth / JWT (Phase 1) ──
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Server-side pepper for HMAC-hashing challenge flags. Treat like a root secret.
FLAG_PEPPER=

# ── GitHub OAuth (Phase 1) ──
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ── Email — Resend (Phase 1) ──
RESEND_API_KEY=
EMAIL_FROM="CyberLearn <no-reply@yourdomain.dev>"

# ── Rate limiting — Upstash Redis ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Realtime — Pusher (Phase 5) ──
PUSHER_APP_ID=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# ── AI Mentor — Anthropic (Phase 6) ──
ANTHROPIC_API_KEY=

# Set to "1" to skip Zod env validation (e.g. CI builds without a database).
SKIP_ENV_VALIDATION=
